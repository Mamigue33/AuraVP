<?xml version="1.0" encoding="utf-8"?>
<layer-list
  xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:id="@android:id/background">
        <shape android:shape="ring" android:innerRadiusRatio="2.5" android:useLevel="false" android:thickness="2.5dip">
            <solid android:color="#ff1f232f" />
        </shape>
    </item>
    <item android:id="@android:id/progress">
        <shape android:shape="ring" android:innerRadiusRatio="2.5" android:useLevel="true" android:thickness="2.5dip">
            <solid android:color="#ffffffff" />
        </shape>
    </item>
</layer-list>